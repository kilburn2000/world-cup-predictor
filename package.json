{
  "name": "worldcup-predictor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=server",
    "db:push": "npm run db:push --workspace=server",
    "seed": "npm run seed --workspace=server",
    "import": "npm run import --workspace=server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "npm test --workspace=server"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
